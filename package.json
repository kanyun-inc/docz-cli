{
  "name": "docz-cli",
  "version": "0.7.0",
  "description": "DocSync CLI — read and write company documents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "docz": "./dist/index.js",
    "docz-cli": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kanyun-inc/docz-cli"
  },
  "license": "MIT",
  "keywords": [
    "docsync",
    "cli",
    "file-sync",
    "document"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "clean": "rm -rf dist node_modules",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.15.0",
    "msw": "^2.8.4",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^4.0.4"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
